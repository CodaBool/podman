[Container]
ContainerName=code
Image=docker.io/gitpod/openvscode-server
PublishPort=3005:3000
Volume=/mnt/volumes:/home/workspace:z
User=1000:1000
RunInit=true

# auto update
AutoUpdate=registry

[Service]

# allow time for a new image to download
TimeoutStartSec=900
Restart=always

[Install]

# automatic startup
WantedBy=default.target
